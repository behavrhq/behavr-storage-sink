# Copy to ".env" in the project root and fill in values. Used when running with profile "prod"
# (Spring loads this file via spring.config.import — Java Properties format: KEY=value, no "export").

# --- Confluent Cloud Kafka ---
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.region.provider.confluent.cloud:9092
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=

# --- AWS S3 (production lake) ---
# Bucket and optional prefix (defaults match application.yml if unset)
BEHAVR_SINK_BUCKET=behavr-lake
BEHAVR_SINK_PREFIX=raw/events

# Region for SDK / SigV4 (also used as behavr.storage.region)
AWS_REGION=us-east-1

# Optional static keys; leave empty on EC2/EKS to use instance or web identity IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
